# =============================================================================
# Единый источник переменных окружения для dev и prod.
# Скопируй этот файл в .env и заполни значения.
#   cp .env.example .env
# =============================================================================

# ----- Общие ------------------------------------------------------------------
COMPOSE_PROJECT_NAME=project_work2
NODE_ENV=development

# Корневой домен (в dev используется .localhost, в prod — реальный).
DOMAIN=localhost
APP_DOMAIN=app.localhost
API_DOMAIN=api.localhost
TRAEFIK_DOMAIN=traefik.localhost

# ----- Traefik ----------------------------------------------------------------
# Email для Let's Encrypt (только prod).
TRAEFIK_ACME_EMAIL=admin@example.com
# htpasswd-строка для доступа к дашборду Traefik (сгенерируй: htpasswd -nbB admin 'pass').
# Экранируй $ как $$ для Docker Compose.
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$examplehashreplace

# ----- PostgreSQL -------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=change_me_strong_password

# ----- Strapi -----------------------------------------------------------------
STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337
STRAPI_URL=http://api.localhost
# Секреты (сгенерируй: openssl rand -base64 32). Несколько ключей через запятую для APP_KEYS.
STRAPI_APP_KEYS=key1,key2,key3,key4
STRAPI_API_TOKEN_SALT=replace_me
STRAPI_ADMIN_JWT_SECRET=replace_me
STRAPI_JWT_SECRET=replace_me
STRAPI_TRANSFER_TOKEN_SALT=replace_me
# Тип БД для Strapi.
DATABASE_CLIENT=postgres
DATABASE_SSL=false

# ----- Auth (users-permissions: refresh-mode + сессии устройств) -------------
# Лайфспаны (секунды). Дефолты Strapi: access 600, idle 14d, max 30d.
UP_ACCESS_TOKEN_LIFESPAN=600
UP_REFRESH_IDLE_LIFESPAN=1209600
UP_REFRESH_MAX_LIFESPAN=2592000

# Имя и атрибуты HttpOnly-cookie для refresh-токена (только web).
UP_REFRESH_COOKIE_NAME=strapi_up_refresh
UP_REFRESH_COOKIE_DOMAIN=
UP_REFRESH_COOKIE_SAMESITE=lax
UP_REFRESH_COOKIE_SECURE=true

# Anti-bruteforce на /auth/local и /auth/refresh.
UP_RATELIMIT_INTERVAL=60000
UP_RATELIMIT_MAX=5

# CSV разрешённых web-Origin'ов для cookie-пути (CSRF-защита).
WEB_ORIGINS=http://app.localhost

# ----- Nuxt -------------------------------------------------------------------
# Публичные (доступны в браузере) — префикс NUXT_PUBLIC_.
NUXT_PUBLIC_SITE_URL=http://app.localhost
NUXT_PUBLIC_API_BASE=http://api.localhost/api
# Приватные (только SSR) — без префикса PUBLIC.
NUXT_API_SECRET=

# ----- Capacitor (iOS / Android) ---------------------------------------------
CAP_APP_ID=com.example.projectwork2
CAP_APP_NAME=ProjectWork2
# В dev — LAN IP машины с Nuxt dev-сервером, чтобы на устройстве работал live reload.
# Пример: http://192.168.1.42:3000. В prod оставь пустым — будет использоваться бандл.
CAP_SERVER_URL=
