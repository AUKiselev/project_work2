{
  "kind": "collectionType",
  "collectionName": "speakers",
  "info": {
    "singularName": "speaker",
    "pluralName": "speakers",
    "displayName": "Speaker",
    "description": "Карточка спикера"
  },
  "options": { "draftAndPublish": true },
  "attributes": {
    "slug": { "type": "uid", "targetField": "fullName" },
    "fullName": { "type": "string", "required": true, "maxLength": 200 },
    "photo": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"]
    },
    "bio": { "type": "richtext" },
    "social": { "type": "json" },
    "events": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::event.event",
      "mappedBy": "speakers"
    }
  }
}
